{
  "name": "codex-pulse",
  "version": "0.2.0",
  "private": true,
  "description": "A fast macOS mini app for Codex usage insights.",
  "author": "Theodor Diaconu",
  "productName": "Codex Pulse",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build:fast": "electron-vite build",
    "build": "npm run typecheck && electron-vite build && electron-builder",
    "build:dir": "npm run typecheck && electron-vite build && electron-builder --dir",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ccusage/codex": "^18.0.10",
    "electron-log": "^5.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.theodordiaconu.codexpulse",
    "productName": "Codex Pulse",
    "icon": "build/icon.png",
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "out/**/*",
      "src/main/assets/**/*",
      "package.json"
    ]
  }
}
